FROM golang:1.22-alpine AS builder

RUN apk add --no-cache git

WORKDIR /app

COPY go-libp2p/ ./
RUN go mod tidy && go build -o /go-libp2p-interop .

# Runtime stage
FROM alpine:3.19
COPY --from=builder /go-libp2p-interop /usr/local/bin/go-libp2p-interop
ENTRYPOINT ["/usr/local/bin/go-libp2p-interop"]
CMD ["server"]
